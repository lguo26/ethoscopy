# ============================================================================
# GOOGLE OAUTH AUTHENTICATOR
# ============================================================================
# Authenticate users via their Google accounts
# Best for: Organizations using Google Workspace, universities with Google
#
# Setup Instructions:
# 1. Go to Google Cloud Console (console.cloud.google.com)
# 2. Create a new project or select existing
# 3. Enable Google+ API
# 4. Go to Credentials > Create Credentials > OAuth 2.0 Client ID
# 5. Set Application type: Web application
# 6. Add Authorized redirect URI: http://your-server:8082/hub/oauth_callback
# 7. Copy the Client ID and Client Secret

# Authenticator type
AUTHENTICATOR_CLASS=google

# OAuth credentials from Google Cloud Console
OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your_google_client_secret_here

# Callback URL (must match what you set in Google Cloud Console)
OAUTH_CALLBACK_URL=http://your-server:8082/hub/oauth_callback

# (Optional) Restrict to Google Workspace domain
# GOOGLE_HOSTED_DOMAIN=yourdomain.com

# Comma-separated list of allowed users (Gmail addresses without @gmail.com or @yourdomain.com)
ALLOWED_USERS=user1,user2,user3

# Comma-separated list of admin users
ADMIN_USERS=your-email-username

# Docker user/group (optional, defaults to 1000:1000)
UID=1000
GID=1000

# JupyterHub and Ethoscope Lab versions
JUPYTER_HUB_TAG=5.3.0
ETHOSCOPE_LAB_TAG=1.1
