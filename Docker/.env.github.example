# ============================================================================
# GITHUB OAUTH AUTHENTICATOR
# ============================================================================
# Authenticate users via their GitHub accounts
# Best for: Open source projects, teams already using GitHub
#
# Setup Instructions:
# 1. Go to GitHub Settings > Developer Settings > OAuth Apps
# 2. Create a new OAuth App
# 3. Set Homepage URL: http://your-server:8082
# 4. Set Authorization callback URL: http://your-server:8082/hub/oauth_callback
# 5. Copy the Client ID and generate a Client Secret

# Authenticator type
AUTHENTICATOR_CLASS=github

# OAuth credentials from GitHub OAuth App
OAUTH_CLIENT_ID=your_github_client_id_here
OAUTH_CLIENT_SECRET=your_github_client_secret_here

# Callback URL (must match what you set in GitHub OAuth App)
OAUTH_CALLBACK_URL=http://your-server:8082/hub/oauth_callback

# (Optional) Restrict to GitHub organization members
# GITHUB_ORG=your-organization-name

# Comma-separated list of allowed users (GitHub usernames)
ALLOWED_USERS=username1,username2,username3

# Comma-separated list of admin users (GitHub usernames)
ADMIN_USERS=your-github-username

# Docker user/group (optional, defaults to 1000:1000)
UID=1000
GID=1000

# JupyterHub and Ethoscope Lab versions
JUPYTER_HUB_TAG=5.3.0
ETHOSCOPE_LAB_TAG=1.1
