# ============================================================================
# KEYCLOAK / GENERIC OIDC AUTHENTICATOR
# ============================================================================
# Authenticate users via Keycloak or any OIDC-compliant provider
# Best for: Organizations with existing SSO, enterprise environments
#
# Setup Instructions for Keycloak:
# 1. Log into your Keycloak Admin Console
# 2. Select your realm (e.g., 'gilestro-lab')
# 3. Go to Clients > Create Client
# 4. Set Client ID: jupyterhub
# 5. Set Client Protocol: openid-connect
# 6. Set Access Type: confidential
# 7. Set Valid Redirect URIs: http://your-server:8082/hub/oauth_callback
# 8. Save and go to Credentials tab to get the Client Secret
# 9. Create users in Keycloak matching your existing home directory names

# Authenticator type
AUTHENTICATOR_CLASS=generic

# OAuth credentials from Keycloak client
OAUTH_CLIENT_ID=jupyterhub
OAUTH_CLIENT_SECRET=your_keycloak_client_secret_here

# Callback URL
OAUTH_CALLBACK_URL=http://your-server:8082/hub/oauth_callback

# Keycloak OIDC endpoints (replace YOUR_KEYCLOAK_SERVER and YOUR_REALM)
# Example: http://keycloak.example.com/realms/gilestro-lab
OAUTH_AUTHORIZE_URL=http://YOUR_KEYCLOAK_SERVER/realms/YOUR_REALM/protocol/openid-connect/auth
OAUTH_TOKEN_URL=http://YOUR_KEYCLOAK_SERVER/realms/YOUR_REALM/protocol/openid-connect/token
OAUTH_USERDATA_URL=http://YOUR_KEYCLOAK_SERVER/realms/YOUR_REALM/protocol/openid-connect/userinfo

# Username claim (Keycloak uses 'preferred_username' by default)
OAUTH_USERNAME_CLAIM=preferred_username

# OAuth scopes (comma-separated, optional)
OAUTH_SCOPE=openid,profile,email

# CRITICAL: Keycloak usernames MUST match existing home directory names exactly
# Comma-separated list of allowed users
ALLOWED_USERS=amadabhushi,ggilestro,mjoyce,lguo,labguest1,labguest2,labguest3,labguest4,labguest5,labguest6,labguest7,labguest8,ethoscopelab

# Comma-separated list of admin users
ADMIN_USERS=ggilestro

# Docker user/group (optional, defaults to 1000:1000)
UID=1000
GID=1000

# JupyterHub and Ethoscope Lab versions
JUPYTER_HUB_TAG=5.3.0
ETHOSCOPE_LAB_TAG=1.1
