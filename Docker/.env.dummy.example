# ============================================================================
# DUMMY AUTHENTICATOR (Simple Shared Password)
# ============================================================================
# Default authentication method - all users share the same password
# Best for: Lab environments, small teams, trusted networks

# Authenticator type (must be 'dummy' for this configuration)
AUTHENTICATOR_CLASS=dummy

# Shared password for all users
DUMMY_PASSWORD=ethoscope

# Comma-separated list of allowed users
ALLOWED_USERS=amadabhushi,ggilestro,mjoyce,lguo,labguest1,labguest2,labguest3,labguest4,labguest5,labguest6,labguest7,labguest8,ethoscopelab

# Comma-separated list of admin users
ADMIN_USERS=ggilestro

# Docker user/group (optional, defaults to 1000:1000)
UID=1000
GID=1000

# JupyterHub and Ethoscope Lab versions
JUPYTER_HUB_TAG=5.3.0
ETHOSCOPE_LAB_TAG=1.1
